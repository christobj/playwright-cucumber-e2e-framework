{
  "name": "playwright-cucumber-e2e-framework",
  "version": "1.0.0",
  "description": "Playwright + Cucumber BDD end-to-end test automation framework for https://automationexercise.com/",
  "private": true,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "cucumber-js",
    "posttest": "node scripts/generate-report.js",
    "test:chromium": "cross-env BROWSER=chromium npm test",
    "test:firefox": "cross-env BROWSER=firefox npm test",
    "test:webkit": "cross-env BROWSER=webkit npm test",
    "test:headed": "cross-env HEADLESS=false npm test",
    "test:debug": "cross-env HEADLESS=false SLOWMO=250 npm test",
    "report:open": "node scripts/open-report.js",
    "lint": "eslint .",
    "lint.fix": "eslint . --fix",
    "format": "prettier --check .",
    "format.fix": "prettier --write .",
    "prepare": "husky"
  },
  "keywords": [
    "playwright",
    "cucumber",
    "bdd",
    "e2e",
    "automation"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@cucumber/cucumber": "^11.2.0",
    "chai": "^4.5.0",
    "dotenv": "^16.4.5",
    "playwright": "^1.49.1"
  },
  "devDependencies": {
    "@cucumber/pretty-formatter": "^1.0.1",
    "@eslint/js": "^9.17.0",
    "@faker-js/faker": "^9.3.0",
    "cross-env": "^7.0.3",
    "cucumber-html-reporter": "^7.1.1",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "prettier": "^3.4.2"
  }
}
